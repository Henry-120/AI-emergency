# 複製此檔為 .env.local，填入實際金鑰後重新啟動 npm run dev
# （.env.local 不會被上傳到 GitHub）

# ---- Firebase（登入 + 醫療卡雲端儲存）----
# 於 Firebase 主控台 → 專案設定 → 一般 → 你的應用程式 → SDK 設定與配置 取得
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---- 其他既有服務（選填）----
# Gemini AI 災害分析
VITE_GEMINI_API_KEY=
# 中央氣象署地震警報（後端使用）
CWA_API_KEY=
